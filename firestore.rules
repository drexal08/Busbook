
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EZ Bus Security Rules Philosophy:
     * 1. System Admin Supremacy: Platform Admin has universal access.
     * 2. Role-Based Access: PASSENGER, OPERATOR (Staff), COMPANY (Business Owner), and ADMIN.
     * 3. Ownership: Users manage their own profiles and data.
     * 4. Company Isolation: COMPANY/OPERATOR only manage their own fleet resources.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_platform_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'byiringirinnocent8@gmail.com' ||
        request.auth.uid == 'iRpF7l7RCpQs4hG5vJ3xqLRRk4T2'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function getUserRole() {
      let data = getUserData();
      return data.role;
    }

    function getCompanyId() {
      return getUserData().companyId;
    }

    function isPassenger() {
      return isSignedIn() && (getUserRole() == 'PASSENGER' || isPlatformAdmin());
    }

    function isOperator() {
      return isSignedIn() && (getUserRole() == 'OPERATOR' || isPlatformAdmin());
    }

    function isCompany() {
      return isSignedIn() && (getUserRole() == 'COMPANY' || isPlatformAdmin());
    }

    // --- Universal Admin Access ---
    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }

    // --- Specific Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && (
        !('role' in request.resource.data) || request.resource.data.role == resource.data.role
      );
      allow delete: if isOwner(userId);

      match /bookings/{bookingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);

        match /payments/{paymentId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
        }
      }
    }

    // Allows COMPANY to view bookings for their trips
    match /{path=**}/bookings/{bookingId} {
      allow read: if isCompany() && get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.transportCompanyId == getCompanyId();
    }

    match /transport_companies/{companyId} {
      allow get, list: if true;
      allow create, update: if isPlatformAdmin() || (isCompany() && companyId == getCompanyId());

      match /buses/{busId} {
        allow get, list: if true;
        allow create, update, delete: if isPlatformAdmin() || (isCompany() && companyId == getCompanyId());
      }

      match /advertisements/{advertisementId} {
        allow get, list: if true;
        allow create, update, delete: if isPlatformAdmin() || (isCompany() && companyId == getCompanyId());
      }
    }

    match /bus_parks/{busParkId} {
      allow get, list: if true;
    }

    match /locations/{locationId} {
      allow get, list: if true;
    }

    match /routes/{routeId} {
      allow get, list: if true;
      allow create, update, delete: if isPlatformAdmin() || (isCompany() && (request.resource.data.companyId == getCompanyId() || resource.data.companyId == getCompanyId()));
    }

    match /trips/{tripId} {
      allow get, list: if true;
      allow create, update: if isPlatformAdmin() || isOperator() || (isCompany() && (request.resource.data.transportCompanyId == getCompanyId() || resource.data.transportCompanyId == getCompanyId()));
      // Allow passengers to update booked seats during purchase
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedSeatNumbers', 'updatedAt']);
    }

    match /roles_platform_admin/{userId} {
      allow get: if isSignedIn();
    }

    match /roles_company_admin/{companyId}/{userId} {
      allow get: if isSignedIn();
    }
  }
}
